# ─── Map Configuration ───────────────────────────────────────────
# Map provider: leaflet (default), google-maps, mapbox
VITE_MAP_PROVIDER=leaflet

# Google Maps API key (required when VITE_MAP_PROVIDER=google-maps)
VITE_GOOGLE_MAPS_API_KEY=

# Mapbox access token (required when VITE_MAP_PROVIDER=mapbox)
VITE_MAPBOX_ACCESS_TOKEN=

# Geocoding service URL (optional, for pincode → lat/lng conversion)
# Leave empty to use the default free postal pincode API for India
VITE_GEOCODING_API_URL=

# ─── API Configuration ────────────────────────────────────────────
# API base URL for authentication and other endpoints
VITE_API_URL=http://localhost:3000
