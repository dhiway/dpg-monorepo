{
  "name": "yellow_dot",
  "display_name": "Yellow Dot",
  "description": "Education focused DOT.",
  "schema_standard": "https://json-schema.org/draft/2020-12/schema",
  "domains": [
    {
      "name": "student",
      "description": "Learners on the network.",
      "default_item_schemas": {
        "profile": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Student Profile",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "grade",
            "city"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "grade": {
              "type": "string",
              "enum": [
                "8",
                "9",
                "10",
                "11",
                "12"
              ]
            },
            "city": {
              "type": "string"
            },
            "preferred_subject": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "name": "tutor",
      "description": "Tutors on the network.",
      "default_item_schemas": {
        "profile": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Tutor Profile",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "subjects",
            "experience_years"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "subjects": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "experience_years": {
              "type": "integer",
              "minimum": 0
            },
            "teaching_mode": {
              "type": "string",
              "enum": [
                "online",
                "offline",
                "hybrid"
              ]
            }
          }
        }
      }
    },
    {
      "name": "coaching_center",
      "description": "Coaching centers on the network.",
      "default_item_schemas": {
        "profile": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Coaching Center Profile",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "city",
            "programs"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "city": {
              "type": "string"
            },
            "programs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "seats_available": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  ],
  "instances": [
    {
      "domain_name": "student",
      "instance_name": "Yellow Dot Student",
      "instance_url": "https://student.yellowdot.example.com",
      "schema_url": null
    },
    {
      "domain_name": "tutor",
      "instance_name": "Yellow Dot Tutor",
      "instance_url": "https://tutor.yellowdot.example.com",
      "schema_url": "https://tutor.yellowdot.example.com/schemas/profile.json"
    },
    {
      "domain_name": "coaching_center",
      "instance_name": "Yellow Dot Coaching",
      "instance_url": "https://coaching.yellowdot.example.com",
      "schema_url": "https://coaching.yellowdot.example.com/schemas/profile.json"
    }
  ],
  "actions": {
    "connect": {
      "description": "Defines which domains can connect to which other domains, what requirement payload they send, and what event payload is returned.",
      "interactions": [
        {
          "from_network": "yellow_dot",
          "from_domain": "student",
          "to_network": "yellow_dot",
          "to_domain": "tutor",
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Tutor Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "subject",
              "goal"
            ],
            "properties": {
              "subject": {
                "type": "string"
              },
              "goal": {
                "type": "string"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Tutor Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "message"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "accepted",
                  "rejected"
                ]
              },
              "message": {
                "type": "string"
              }
            }
          }
        },
        {
          "from_network": "yellow_dot",
          "from_domain": "student",
          "to_network": "yellow_dot",
          "to_domain": "coaching_center",
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Coaching Center Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "program",
              "goal"
            ],
            "properties": {
              "program": {
                "type": "string"
              },
              "goal": {
                "type": "string"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Coaching Center Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "message"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "accepted",
                  "rejected"
                ]
              },
              "message": {
                "type": "string"
              }
            }
          }
        },
        {
          "from_network": "yellow_dot",
          "from_domain": "tutor",
          "to_network": "yellow_dot",
          "to_domain": "student",
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Tutor To Student Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "offered_subject",
              "availability"
            ],
            "properties": {
              "offered_subject": {
                "type": "string"
              },
              "availability": {
                "type": "string"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Tutor To Student Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "message"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "accepted",
                  "rejected"
                ]
              },
              "message": {
                "type": "string"
              }
            }
          }
        },
        {
          "from_network": "yellow_dot",
          "from_domain": "tutor",
          "to_network": "yellow_dot",
          "to_domain": "coaching_center",
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Tutor To Coaching Center Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "offered_subject",
              "engagement_type"
            ],
            "properties": {
              "offered_subject": {
                "type": "string"
              },
              "engagement_type": {
                "type": "string",
                "enum": [
                  "guest_faculty",
                  "full_time",
                  "part_time"
                ]
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Tutor To Coaching Center Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "message"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "accepted",
                  "rejected"
                ]
              },
              "message": {
                "type": "string"
              }
            }
          }
        },
        {
          "from_network": "yellow_dot",
          "from_domain": "coaching_center",
          "to_network": "yellow_dot",
          "to_domain": "student",
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Coaching Center To Student Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "program_name"
            ],
            "properties": {
              "program_name": {
                "type": "string"
              },
              "scholarship_available": {
                "type": "boolean"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Coaching Center To Student Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "message"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "accepted",
                  "rejected"
                ]
              },
              "message": {
                "type": "string"
              }
            }
          }
        },
        {
          "from_network": "yellow_dot",
          "from_domain": "coaching_center",
          "to_network": "yellow_dot",
          "to_domain": "tutor",
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Coaching Center To Tutor Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "subject",
              "program_name"
            ],
            "properties": {
              "subject": {
                "type": "string"
              },
              "program_name": {
                "type": "string"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Coaching Center To Tutor Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "message"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "accepted",
                  "rejected"
                ]
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      ]
    }
  }
}
