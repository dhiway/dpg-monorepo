{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "*"
  ],
  "globalDependencies": [
    ".env"
  ],
  "tasks": {
    "build": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false,
      "persistent": true
    },
    "preview": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "start": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "db:pull": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false
    },
    "db:push": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false
    },
    "db:generate": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false
    },
    "db:migrate": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false
    },
    "db:studio": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false
    }
  }
}
